monthly_O18 <- read_csv("../Data/Modern/monthly_flask_o18_mlo.csv", skip = 58) #Column 5 is what we want
monthly_C13 <- read_csv("../Data/Modern/monthly_flask_c13_mlo.csv", skip = 58) #Column 5 is what we want
monthly_O18
monthly_O18 <- monthly_O18[-1:-2,]
monthly_O18
monthly_C13 <- monthly_C13[-1:-2,]
monthly_C13
monthly_O18
View(monthly_O18)
monthly_O18 %>%
rename("18O" == `18O...5`)
View(monthly_O18)
monthly_O18
monthly_O18 %>%
rename("18O" == `18O...5`)
monthly_O18 %>%
filter(`18O...5` == "NaN")
colnames(monthly_C13)[5] <- "18O"
monthly_C13
colnames(monthly_O18)[5] <- "18O"
monthly_O18
colnames(monthly_C13)[5] <- "13C"
monthly_C13
monthly_C13 %>%
mutate(`13C` = if(`13C` == "NaN", NA))
monthly_C13 %>%
mutate(`13C` = if_else(`13C` == "NaN", NA, `13C`))
monthly_C13 %>%
mutate(`13C` = if_else(`13C` == "NaN", NA, `13C`)) %>%
filter(`13C` != NA)
monthly_C13 %>%
filter(`13C` != "NaN")
monthly_C13 %>%
filter(`13C` != "NaN") %>% #remove NAs
mutate(`13C` = as.numeric(`13C`))
monthly_O18 %>%
filter(`18O` != "NaN") %>% #remove NAs
mutate(`18O` = as.numeric(`18O`))
monthly_O18 <- monthly_O18 %>%
filter(`18O` != "NaN") %>% #remove NAs
mutate(`18O` = as.numeric(`18O`))
monthly_C13 <- monthly_C13 %>%
filter(`13C` != "NaN") %>% #remove NAs
mutate(`13C` = as.numeric(`13C`))
monthly_C13
View(organic_hg_joined)
